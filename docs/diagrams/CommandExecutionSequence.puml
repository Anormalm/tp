@startuml
title Generic Command Execution Sequence
autoactivate on

actor User
participant "app:Crypto1010" as App
participant "parser:Parser" as Parser
participant "cmd:Command" as Cmd
participant "chain:Blockchain" as Chain
participant "walletManager:WalletManager" as WM
participant "walletStorage:WalletStorage" as WS
participant "blockchainStorage:BlockchainStorage" as BS

User -> App: <command text>
App -> Parser: parse(input)
Parser --> App: new ConcreteCommand(...)
App -> Cmd: execute(chain, in)
Cmd -> Chain: query/mutate state
Cmd -> WM: query/mutate state (optional)
Cmd --> App: completed
App -> BS: save(chain)
App -> WS: save(walletManager)
App --> User: command result

@enduml
